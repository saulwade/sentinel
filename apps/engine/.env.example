# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# HTTP port for the engine (default: 3001)
PORT=3001

# SQLite database path (default: ./data/sentinel.db)
DB_PATH=./data/sentinel.db

# Comma-separated allowed CORS origins
# In production: ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
